# S3 上传配置文件
# 请将以下占位符替换为你的实际配置信息

# AWS S3 兼容存储凭证
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 存储桶配置
S3_BUCKET_NAME=
S3_DIRECTORY=t/
AWS_REGION=cn-east-1
S3_ENDPOINT_URL=

# 上传配置
# 是否包含微软拼音自定义短语文件 (true/false) 该文件是系统自带的那个lex文件
INCLUDE_LEX_FILE=true

# 同步文件配置 (支持通配符和具体路径，多个用逗号分隔)
# 示例: *.txt,*.csv,config/*.json,docs/README.md,specific_file.txt
SYNC_FILES=*.txt,*.csv